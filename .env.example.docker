# ═══════════════════════════════════════════════════════
# St0r Docker Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and customize for your environment

# SECTION 1: Database Configuration
# ═══════════════════════════════════════════════════════
DB_ROOT_PASSWORD=rootpass123
DB_NAME=urbackup_gui
DB_USER=urbackup
DB_PASSWORD=urbackup_gui_password

# SECTION 2: Security Keys
# ═══════════════════════════════════════════════════════
# Generate secure random values:
#   openssl rand -hex 32
#
# IMPORTANT: Do NOT use the placeholder values in production!
JWT_SECRET=your_jwt_secret_here_change_me_now_with_openssl_rand_hex_32
APP_SECRET_KEY=your_app_secret_key_here_change_me_now_with_openssl_rand_hex_32

# SECTION 3: UrBackup Server Configuration
# ═══════════════════════════════════════════════════════
# Path to UrBackup backup_server.db on the HOST machine
# Default: /var/urbackup/backup_server.db
URBACKUP_DB_PATH=/var/urbackup/backup_server.db

# UrBackup API URL
# For UrBackup running on the HOST:
#   URBACKUP_API_URL=http://host.docker.internal:55414/x
# For UrBackup running in another container:
#   URBACKUP_API_URL=http://urbackup-container-name:55414/x
URBACKUP_API_URL=http://host.docker.internal:55414/x

# UrBackup admin credentials
URBACKUP_USERNAME=admin
URBACKUP_PASSWORD=

# SECTION 4: Port Configuration (Optional)
# ═══════════════════════════════════════════════════════
# HTTP port for web UI (default: 80)
HTTP_PORT=80

# Backend API port (default: 3000, optional)
API_PORT=3000