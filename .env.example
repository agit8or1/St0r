# st0r Database Configuration (MariaDB)
DB_ROOT_PASSWORD=                    # required: generate with: openssl rand -hex 32
DB_NAME=urbackup_gui
DB_USER=urbackup
DB_PASSWORD=                         # required: generate with: openssl rand -hex 32

# Application Configuration
NODE_ENV=production
JWT_SECRET=                          # required: generate with: openssl rand -hex 64

# Port Configuration
HTTP_PORT=80
HTTPS_PORT=443

# UrBackup Server Configuration (Local Instance)
# Path to the UrBackup SQLite database
URBACKUP_DB_PATH=/var/urbackup/backup_server.db
# UrBackup API URL (for write operations like starting backups)
URBACKUP_API_URL=http://localhost:55414/x
# UrBackup server credentials (for API operations)
URBACKUP_USERNAME=admin
URBACKUP_PASSWORD=
