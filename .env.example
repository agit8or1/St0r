# st0r — Backend Environment Configuration
# Copy this file to backend/.env and fill in the required values.
# NEVER commit backend/.env to version control.

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (MariaDB) ────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=urbackup_gui
DB_USER=urbackup
DB_PASSWORD=                         # required — openssl rand -hex 32

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=                          # required — openssl rand -hex 64
# 32-byte hex key used for AES-256-GCM encryption of replication SSH keys/passwords
APP_SECRET_KEY=                      # required — openssl rand -hex 32

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Override NIC speed for the network gauge (Mbps). Auto-detected via sysfs,
# but VMs with VirtIO often return -1. Set explicitly for accurate gauge.
# e.g. 1000 = 1GbE, 10000 = 10GbE, 25000 = 25GbE
NETWORK_LINK_SPEED_MBPS=1000

# ── UrBackup Server ───────────────────────────────────────────────────────────
URBACKUP_DB_PATH=/var/urbackup/backup_server.db
URBACKUP_API_URL=http://localhost:55414/x
URBACKUP_USERNAME=admin
URBACKUP_PASSWORD=                   # leave empty if UrBackup has no admin password

# ── Internet Client URL (embedded in generated installers) ───────────────────
URBACKUP_SERVER_HOST=                # e.g. backup.example.com
URBACKUP_SERVER_FQDN=                # same as HOST unless you need them separate
URBACKUP_SERVER_PORT=55414
